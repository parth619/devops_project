<!DOCTYPE html>
<html>
<head>
    <title>Bonafide Entry</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-10 flex justify-center">
    <form action="/generate" method="POST" enctype="multipart/form-data" class="bg-white p-8 rounded shadow-md w-full max-w-md">
        <h1 class="text-xl font-bold mb-4">Student Details</h1>
        <select name="prefix" class="w-full mb-2 p-2 border"><option>Mast.</option><option>Miss.</option></select>
        <input type="text" name="name" placeholder="Student Name" class="w-full mb-2 p-2 border" required>
        <input type="text" name="className" placeholder="Class" class="w-full mb-2 p-2 border" required>
        <input type="text" name="mother_name" placeholder="Mother's Name" class="w-full mb-2 p-2 border" required>
        <input type="text" name="dob" placeholder="DOB (DD/MM/YYYY)" class="w-full mb-2 p-2 border" required>
        <input type="text" name="dob_in_words" placeholder="DOB in Words" class="w-full mb-2 p-2 border" required>
        <input type="text" name="caste" placeholder="Caste" class="w-full mb-2 p-2 border" required>
        <input type="text" name="admission_no" placeholder="Admission No" class="w-full mb-2 p-2 border" required>

        <div class="mb-4">
            <label class="block text-sm font-medium mb-2">Student Photo (Optional)</label>
            <input id="student_photo" type="file" name="student_photo" accept="image/*" class="hidden">
            <div id="dropzone" class="w-full p-4 border-2 border-dashed rounded text-center text-sm text-gray-600 cursor-pointer bg-gray-50">
                <div class="font-semibold">Choose a file</div>
                <div class="mt-1">or drag and drop an image here</div>
                <div id="fileName" class="mt-2 text-gray-800"></div>
            </div>
        </div>

        <button type="submit" class="w-full bg-blue-600 text-white p-2 rounded">Generate PDF</button>
    </form>

    <script>
        const input = document.getElementById('student_photo');
        const dropzone = document.getElementById('dropzone');
        const fileName = document.getElementById('fileName');

        function setFileLabel(file) {
            fileName.textContent = file ? file.name : '';
        }

        dropzone.addEventListener('click', () => input.click());
        input.addEventListener('change', () => setFileLabel(input.files && input.files[0]));

        dropzone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropzone.classList.add('border-blue-500');
        });

        dropzone.addEventListener('dragleave', () => {
            dropzone.classList.remove('border-blue-500');
        });

        dropzone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropzone.classList.remove('border-blue-500');

            const files = e.dataTransfer.files;
            if (!files || !files.length) return;

            const dt = new DataTransfer();
            dt.items.add(files[0]);
            input.files = dt.files;
            setFileLabel(files[0]);
        });
    </script>
</body>
</html>