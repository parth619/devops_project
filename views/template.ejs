<!DOCTYPE html>
<html>
<head>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        @page {
            size: A4 landscape;
            margin: 0;
        }

        body {
            font-family: 'Times New Roman', serif;
            background: white;
            color: black;
        }

        .border-box {
            border: 5px double black;
            border-radius: 40px;
            width: 297mm;
            height: 210mm;
            padding: 16mm;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
        }

        .top-row {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 14mm;
        }

        .header {
            flex: 1;
            text-align: center;
        }

        .school-name { font-size: 28pt; font-weight: bold; text-decoration: underline; color: black; }

        .photo-box {
            flex: 0 0 auto;
            border: 1px solid black;
            width: 38mm;
            height: 48mm;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            font-size: 12pt;
            padding: 2mm;
        }

        .photo-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .title { text-align: center; font-size: 20pt; font-weight: bold; text-decoration: underline; margin: 10mm 0 6mm; }
        .content { flex: 1; line-height: 2.2; font-size: 15pt; text-align: justify; color: black; }
        .u-field { border-bottom: 2px solid black; font-weight: bold; padding: 0 5px; display: inline-block; min-width: 50px; }

        .footer {
            margin-top: auto;
            padding-top: 8mm;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 12mm;
        }

        .sign-area {
            width: 120mm;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .sign-row {
            display: flex;
            align-items: flex-end;
            justify-content: flex-end;
            gap: 10mm;
            width: 100%;
        }

        .seal { width: 30mm; height: auto; }
        .signature { width: 70mm; height: auto; }
    </style>
</head>
<body>
    <div class="border-box">
        <div class="top-row">
            <div class="header">
                <div class="school-name">SHRI SATYASAI VIDYAMANDIR</div>
                <div style="font-size: 14pt; font-weight: bold;">Ambika Nagar Narsala, Nagpur</div>
            </div>
            <div class="photo-box">
                <% if (student_photo_url && student_photo_url.length > 5) { %>
                    <img
                        src="<%= student_photo_url %>"
                        alt="Student photo"
                        onerror="this.style.display='none'; this.parentElement.textContent='Affix Photo';"
                    >
                <% } else { %>
                    Affix Photo
                <% } %>
            </div>
        </div>

        <div class="title">BONAFIED CERTIFICATE</div>
        <div class="content">
            This is to certify that <span class="u-field"><%= prefix %> <%= student_name %></span><br>
            Is bonafied student of Academic year <span class="u-field">2025-26</span> of Class <span class="u-field"><%= className %></span> His/Her<br>
            mother name is <span class="u-field"><%= mother_name %></span> And Date of Birth is <span class="u-field"><%= dob %></span> (In words: <span class="u-field"><%= dob_in_words %></span>) And Cast <span class="u-field"><%= caste %></span> As per School record. And His/Her Admission No. is <span class="u-field"><%= admission_no %></span>
        </div>
        <div class="footer">
            <div style="font-weight: bold; font-size: 14pt;">Place: Nagpur<br>Date: <%= new Date().toLocaleDateString('en-GB') %></div>
            <div class="sign-area">
                <div class="sign-row">
                    <img src="<%= sealData %>" class="seal" alt="School seal">
                    <img src="<%= signData %>" class="signature" alt="Headmaster signature">
                </div>
                <div style="font-weight:bold; font-size: 14pt; margin-top: 6mm;">Headmaster</div>
            </div>
        </div>
    </div>
</body>
</html>